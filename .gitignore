.venv/
__pycache__/
node_modules/
*.pyc
.ruff_cache/
.playwright-mcp/
.claude/
.streamlit/secrets.toml

# personal game data, never version-controlled
*.db
*.db-wal
*.db-shm
# per-PID DuckDB snapshot copies (dashboard/_common.py, BRIEF S6k) --
# left behind if the dev server is killed; the *.db rule above doesn't
# match their .duck-snapshot-<pid> suffix
*.duck-snapshot-*
# sample.pgn was copied from the original chess-analyzer project during
# Phase A for local testing convenience and contains real personal game
# data (the original author's real lichess username plus real opponent
# usernames) -- caught before ever being pushed (see BRIEF.md S5/Phase C
# for the full incident) and removed for good. Never re-add a PGN fixture
# copied from that project; a fresh, synthetic, or freshly-fetched-from-
# a-real-public-account fixture is fine, copying private personal data
# into this public repo is not.
sample.pgn

# private project docs -- never version-controlled in the open-core repo
CLAUDE.md
BRIEF.md

# local-only generated artifacts (anchored to repo root -- PyInstaller output)
/dist/
/build/
# build-time-downloaded DuckDB extension(s) -- fetched fresh per platform/
# duckdb-pin by scripts/fetch_duckdb_extensions.py, never committed
/build_assets/
# NOT *.spec -- chesswright.spec is a real, deliberate, version-controlled
# build config (Phase C), not a PyInstaller-auto-generated throwaway. A
# blanket *.spec rule here would silently exclude it from every commit.
